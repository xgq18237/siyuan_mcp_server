{
  "mcpServers": {
    "mcp-now": {
      "transportType": "sse",
      "url": "http://localhost:8040/cursor/sse"
    },
    "siyuan_note": {
      "command": "node",
      "args": ["./dist/index.js"],
      "env": {
        "SIYUAN_URL": "http://127.0.0.1:6806",
        "SIYUAN_TOKEN": "your-api-token-here",
        "SIYUAN_MCP_ALLOW_DESTRUCTIVE": "0"
      }
    }
  }
}
