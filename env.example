SIYUAN_URL=http://127.0.0.1:6806
SIYUAN_TOKEN=your-api-token-here

# 危险删除和覆盖操作默认关闭
SIYUAN_MCP_ALLOW_DESTRUCTIVE=0

# 默认仅允许 SELECT/CTE
SIYUAN_MCP_ALLOW_UNSAFE_SQL=0
SIYUAN_MCP_SQL_MAX_ROWS=200

# 工作空间写入路径和本地上传目录
SIYUAN_MCP_WRITE_PATH_PREFIXES=/data/assets,/temp
# Windows 多目录使用分号，Linux/macOS 使用冒号
# SIYUAN_MCP_UPLOAD_ROOTS=C:\Users\me\Pictures;C:\Users\me\Documents

SIYUAN_MCP_TIMEOUT_MS=20000
SIYUAN_MCP_MAX_RESPONSE_BYTES=10485760
SIYUAN_MCP_MAX_TEXT_CHARS=30000
SIYUAN_MCP_DEBUG=0
