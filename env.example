SIYUAN_HOST=127.0.0.1
SIYUAN_PORT=6806
SIYUAN_TOKEN=your-api-token-here

# 可选：完整 URL 会覆盖 SIYUAN_HOST 和 SIYUAN_PORT，
# 可用于 HTTP/HTTPS 远程实例、反向代理或带路径前缀的实例。
# SIYUAN_URL=https://siyuan.example.com

# 可选：仅在显式设为 true/1 时拒绝危险删除和覆盖操作
SIYUAN_MCP_PROTECT_DESTRUCTIVE=false

# 工作空间写入路径和本地上传目录
SIYUAN_MCP_WRITE_PATH_PREFIXES=/data/assets,/temp
# Windows 多目录使用分号，Linux/macOS 使用冒号
# SIYUAN_MCP_UPLOAD_ROOTS=C:\Users\me\Pictures;C:\Users\me\Documents

SIYUAN_MCP_TIMEOUT_MS=120000
SIYUAN_MCP_MAX_RESPONSE_BYTES=10485760
SIYUAN_MCP_MAX_TEXT_CHARS=30000
SIYUAN_MCP_DEBUG=0
