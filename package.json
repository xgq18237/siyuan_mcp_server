{
  "name": "siyuan-mcp",
  "version": "1.1.0",
  "description": "Safe, structured Model Context Protocol server for SiYuan Note",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "siyuan-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "npm run check && npm run build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run build",
    "test:docker": "docker build -t siyuan-mcp-server:test .",
    "prepublishOnly": "npm test",
    "publish:npm": "npm publish",
    "publish:docker": "docker build -t zhizhiqq/siyuan-mcp:latest . && docker push zhizhiqq/siyuan-mcp:latest",
    "publish:both": "npm run publish:npm && npm run publish:docker"
  },
  "keywords": [
    "siyuan",
    "mcp",
    "model-context-protocol",
    "note-taking",
    "api",
    "typescript",
    "cli"
  ],
  "author": "xgq18237",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xgq18237/siyuan_mcp_server.git"
  },
  "bugs": {
    "url": "https://github.com/xgq18237/siyuan_mcp_server/issues"
  },
  "homepage": "https://github.com/xgq18237/siyuan_mcp_server#readme",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.0.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
